# Novus AI Dynamics — Smart Prosthetics — AI-Adaptive Myoelectric Limb Platform
# Copy this file to .env and fill in your values

# Application
APP_ENV=development
APP_PORT=8000
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=postgresql://novus:password@localhost:5432/novus_smart_prosthetics
REDIS_URL=redis://localhost:6379/0

# AWS
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=me-south-1
S3_BUCKET=novus-smart-prosthetics-data

# AI / ML
MODEL_PATH=./models/
INFERENCE_DEVICE=cuda  # or cpu

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
